{
  "name": "micro-measure-tool",
  "private": true,
  "workspaces": [
    "packages/@sailing3d/*",
    "packages/@micro-measure-tool/*"
  ],
  "scripts": {
    "dev": "npm -w @micro-measure-tool/app run dev",
    "dev:https": "node scripts/dev-https.js",
    "build": "npm -w @micro-measure-tool/app run build",
    "deploy": "bash scripts/deploy.sh",
    "preview": "npm -w @micro-measure-tool/app run preview",
    "lint": "npm -w @micro-measure-tool/app run lint",
    "typecheck": "npm -w @micro-measure-tool/app run typecheck"
  }
}
